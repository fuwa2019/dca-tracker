# 复制为 .env.local 并填实际值（前端用）
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGci...
VITE_QUOTE_WORKER_URL=https://your-quote-worker.workers.dev

# 本地版（离线）开关。设为 1 时：免邮箱登录，不连 Supabase / Quote Worker，
# 直接展示内置 10 年 QQQ 定投模拟数据（src/data/local-dataset.json）。
# 云端正式部署保持 0/留空；本地版用 `npm run build:local`（脚本会注入 =1）。
VITE_LOCAL_MODE=0

# Quote Worker only. Do not prefix these with VITE_ and do not put secrets in the browser bundle.
MARKET_DATA_PROVIDER=schwab
SCHWAB_CLIENT_ID=your_schwab_app_key
SCHWAB_CLIENT_SECRET=
SCHWAB_REDIRECT_URI=http://localhost:8787/api/schwab/oauth/callback
SCHWAB_REFRESH_TOKEN=
